<idea-plugin>
    <id>com.cryptiklemur.riderilspy</id>
    <name>ILSpy Integration</name>
    <vendor email="cryptiklemur@gmail.com" url="https://github.com/cryptiklemur">cryptiklemur</vendor>

    <description><![CDATA[
        Replaces Rider's built-in decompiler with ILSpy for assembly browsing,
        goto-definition into external sources, and debug-data driven navigation.
    ]]></description>

    <depends>com.intellij.modules.rider</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- id must match PAGE_ID in IlSpyOptionsPage.kt (canonical source)
             and the Pid constant in ReSharperPlugin/RiderIlSpy/IlSpyOptionsPage.cs. -->
        <applicationConfigurable instance="com.cryptiklemur.riderilspy.IlSpyOptionsPage"
                                 id="RiderIlSpyOptionsPage"
                                 displayName="ILSpy Decompiler"/>
        <applicationService serviceImplementation="com.cryptiklemur.riderilspy.internals.IlSpyFrontendSettings"/>
        <projectService serviceImplementation="com.cryptiklemur.riderilspy.IlSpyProtocolHost"/>
        <statusBarWidgetFactory id="RiderIlSpy.ModeStatusBarWidget"
                                implementation="com.cryptiklemur.riderilspy.IlSpyModeStatusBarWidgetFactory"
                                order="last"/>
        <!-- Notification group for SaveAsProjectAction completion + failure
             messages. Balloon (not toolwindow) so success/failure surfaces
             outside whichever tool window is focused. -->
        <notificationGroup id="RiderIlSpy" displayType="BALLOON"/>
    </extensions>

    <actions>
        <!-- "Save Decompiled Assembly as Project..." — see SaveAsProjectAction.kt.
             Lives on the right-click of any managed binary the user can already
             see in the IDE: Solution Explorer references (assembly + project
             refs), NuGet PackageReferences (also surface under the references
             group), and the standalone Assembly Explorer. No Tools-menu entry
             — the action's update() requires an in-context assembly, so a
             menubar surface with no candidate would be permanently disabled. -->
        <action id="RiderIlSpy.SaveAsProjectAction"
                class="com.cryptiklemur.riderilspy.SaveAsProjectAction"
                text="Save Decompiled Assembly as Project..."
                description="Decompile this managed .dll or .exe to a buildable C# project tree using ILSpy.">
            <add-to-group group-id="SolutionExplorerPopupMenuForReference" anchor="last"/>
            <add-to-group group-id="AssemblyExplorerPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
